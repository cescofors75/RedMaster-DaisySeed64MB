+        step(INST_COWBELL, cowbell);
+        step(INST_CYMBAL,  cymbal);
+        step(INST_RIMSHOT, rimshot);
+        step(INST_SHAKER,  shaker);
+        step(INST_CLAVE,   clave);
+        step(INST_HI_PERC, hiPerc);
