diff --git a/DaisySeed/synth/tr505.h b/DaisySeed/synth/tr505.h
index 746ace1..520ad43 100644
--- a/DaisySeed/synth/tr505.h
+++ b/DaisySeed/synth/tr505.h
@@ -72,6 +72,10 @@ static inline float Clamp(float v, float lo, float hi) {
 
 /* tanh(x) Pade 3/3: error < 0.4% en [-4,4]  ~3x mas rapido */
 static inline float FastTanh(float x) {
+    /* El Pade 3/3 solo satura en [-3,3]; fuera de ese rango vuelve a crecer
+     * (no es un limitador real). Acotamos la entrada para que tope en +-1.0
+     * (f(3)=1.0 exacto) y no genere transientes asperos en golpes fuertes. */
+    x = Clamp(x, -3.0f, 3.0f);
     const float x2 = x * x;
     return x * (27.0f + x2) / (27.0f + 9.0f * x2);
 }
